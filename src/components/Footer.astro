---
const year = new Date().getFullYear();
---
<footer style="background:var(--eco-dark);color:var(--eco-pale);padding:2.5rem 0 1.5rem;margin-top:4rem;">
  <div class="container" style="display:grid;grid-template-columns:2fr 1fr 1fr;gap:2rem;margin-bottom:1.5rem;">
    <div>
      <h3 style="color:var(--eco-light);font-size:1.1rem;margin-bottom:0.75rem;">OZE Poznań</h3>
      <p style="font-size:0.9rem;color:var(--accent);line-height:1.6;">Lokalny portal ekologiczny o odnawialnych źródłach energii w Poznaniu i Wielkopolsce.</p>
    </div>
    <div>
      <h4 style="color:var(--eco-light);font-size:0.75rem;letter-spacing:0.08em;text-transform:uppercase;margin-bottom:0.6rem;">Nawigacja</h4>
      <a href="/" style="display:block;color:var(--accent);font-size:0.9rem;margin-bottom:0.4rem;">Strona główna</a>
      <a href="/blog" style="display:block;color:var(--accent);font-size:0.9rem;">Artykuły</a>
    </div>
    <div>
      <h4 style="color:var(--eco-light);font-size:0.75rem;letter-spacing:0.08em;text-transform:uppercase;margin-bottom:0.6rem;">Partner</h4>
      <a href="https://ecoaudyt.app" target="_blank" style="color:var(--eco-light);font-weight:700;font-size:0.9rem;">ecoaudyt.app →</a>
    </div>
  </div>
  <div style="border-top:1px solid var(--eco-mid);padding-top:1rem;text-align:center;">
    <p style="font-size:0.8rem;color:var(--text-muted);">© {year} OZE Poznań · Wielkopolska</p>
  </div>
</footer>
